{
  "name": "genai-root",
  "version": "1.0.0",
  "description": "Root package for running both Frontend and Backend",
  "scripts": {
    "backend": "npm run dev --prefix Backend",
    "frontend": "npm run dev --prefix Frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "dependencies": {
    "@google/genai": "^2.8.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
